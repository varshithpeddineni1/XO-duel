# Copy to .env and fill in real values. Never commit .env (REPO-4, SEC-1).

# ---- Server ----

# development | production | test
NODE_ENV=development

# Port the Express + Socket.io server listens on
PORT=3000

# Postgres connection string. Schema is managed by node-pg-migrate (server/migrations).
DATABASE_URL=postgres://xo_duel:xo_duel@localhost:5432/xo_duel

# express-session signing secret — at least 32 random bytes, unique per environment, never
# reused. Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# The single admin account (SEC-2). There is no admin self-registration.
# Generate the hash with: npm run hash-admin -- '<your-passcode>'
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-argon2-hash-from-npm-run-hash-admin

# Origin allowed to call the REST API / open the Socket.io connection (CORS).
CLIENT_ORIGIN=http://localhost:5173

# ---- Client (Vite only exposes vars prefixed VITE_ to browser code) ----

VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# ---- CI only (not needed for local dev) ----

# Anthropic API key used by .github/workflows/pr-review.yml (CI-4). Set as a repo secret,
# never in .env.
# ANTHROPIC_API_KEY=
